public class Aluno {
    public String nome;
    public int nota;
    public int matricula;
    
    public Aluno(int matricula, String nome, int nota){
        this.matricula= matricula;
        this.nome = nome;
        this.nota = nota;
        
        System.out.println("Nome: "+nome+"Matricula:"+matricula+"Nota: "+nota);
    }

}
